# ────────────────────────────────────────────────────────────────────────────
# Omnia Protocol Interface — Environment Variables
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only (never sent to the client).

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL, anon public key, service_role key
#
# NEXT_PUBLIC_SUPABASE_URL is safe for the browser (it's the Postgres URL
# exposed via the Supabase API gateway, not the raw DB connection string).
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY is safe for the browser — it only grants
# access permitted by Row Level Security policies.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS. NEVER expose this to the browser.
# It's used only in server-side route handlers (/api/sync, /api/node-token).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Omnia Node ──────────────────────────────────────────────────────────────
# The node's HTTP URL as reachable from the Next.js server (for the sync
# route). In Codespaces, this is the forwarded port URL.
#
# OMNIA_JWT_SECRET must match the secret the node was started with
# (OMNIA_JWT_SECRET env var on the node). The dashboard's server-side
# /api/node-token route uses this to mint per-user JWTs.
#
# OMNIA_NODE_URL is the node URL as the Next.js server reaches it (for sync).
# NEXT_PUBLIC_OMNIA_NODE_URL is the node URL as the browser reaches it
# (for direct API calls). In Codespaces these are often different — the
# browser needs the public forwarded URL, the server can use localhost.

OMNIA_JWT_SECRET=omnia-testnet-jwt-secret-CHANGE-ME
OMNIA_NODE_URL=http://localhost:9090
NEXT_PUBLIC_OMNIA_NODE_URL=https://your-codespace-9090.app.github.dev

# ── Optional: sync interval ─────────────────────────────────────────────────
# How often (in seconds) the client-side sync hook polls the node and
# mirrors data to Supabase. Default: 30 seconds.
SYNC_INTERVAL_SECONDS=30
