# ────────────────────────────────────────────────────────────────────────────
# Omnia Protocol Interface — Environment Variables
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (local dev) and configure the same vars in
# Vercel → Project → Settings → Environment Variables (production).
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only (never sent to the client).

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL, anon public key, service_role key
#
# NEXT_PUBLIC_SUPABASE_URL is safe for the browser (it's the Postgres URL
# exposed via the Supabase API gateway, not the raw DB connection string).
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY is safe for the browser — it only grants
# access permitted by Row Level Security policies.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS. NEVER expose this to the browser.
# It's used only in server-side route handlers (/api/sync, /api/auth/session).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Omnia Node ──────────────────────────────────────────────────────────────
# The node's HTTP URL as reachable from the Next.js server (for /api/sync).
#
# IMPORTANT for production: this must be a URL the Vercel server can reach.
# Localhost won't work on Vercel — use your deployed node's public URL
# (e.g. your Codespace's forwarded port, or a real deployment).
#
# OMNIA_JWT_SECRET must match the secret the node was started with
# (OMNIA_JWT_SECRET env var on the node). The dashboard's server-side
# /api/auth/session route uses this to mint per-user JWTs.

OMNIA_JWT_SECRET=omnia-testnet-jwt-secret-CHANGE-ME
OMNIA_NODE_URL=http://localhost:9090

# ── Vercel Cron Secret (optional but recommended) ──────────────────────────
# When set, /api/sync requires `Authorization: Bearer <CRON_SECRET>` header.
# Vercel Cron automatically sends this header — protects against randoms
# triggering sync runs.
#
# Generate one with: openssl rand -hex 32
# Then set the same value here AND in Vercel → Settings → Environment Variables.

CRON_SECRET=your-random-secret-here
